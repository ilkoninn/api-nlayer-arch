{
  "Api": {
    "BaseUrl": "https://app.runasp.net/api",
    "SwaggerUrl": "https://app.runasp.net/swagger"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_REMOTE_HOST;Port=3306;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_REMOTE_DB_PASSWORD;SslMode=Preferred"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_HOSTING_JWT_SECRET",
    "Issuer": "API",
    "Audience": "APIUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://web.vercel.app",
      "http://localhost:5174",
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  }
}
